---
import Layout from '@/layouts/Layout.astro';
import { ContentService } from '@/lib/content';
import type { Profile, Contact } from '@/types';
import Tile from '@/components/Tile.astro';
const profile = ContentService.getSync<Profile>('profile');
const contact = ContentService.getSync<Contact>('contact');
---
<Layout title={`${profile.name} - Contact`} description={`Contact ${profile.name}`}>
    <div class="band">
        <div class="container">
            <div class="band-header"><h1>Let's talk</h1></div>
        </div>
    </div>
    <section class="tiles-section container">
        <div class="tiles-grid">
            <Tile title="Contact form" subtitle="I'll get back to you soon">
                <form class="contact-form" action={`https://formspree.io/f/${contact.formspreeId}`} method="POST">
                    <div class="row">
                        <div class="col"><label for="firstName">First Name *</label><input required name="firstName" id="firstName" type="text" /></div>
                        <div class="col"><label for="lastName">Last Name *</label><input required name="lastName" id="lastName" type="text" /></div>
                    </div>
                    <label for="email">Email *</label><input required name="email" id="email" type="email" />
                    <label for="subject">Subject</label><input name="subject" id="subject" type="text" />
                    <label for="message">Message</label><textarea name="message" id="message" rows="4"></textarea>
                    <input type="hidden" name="_replyto" value="" />
                    <button class="btn btn-primary" type="submit">Send</button>
                </form>
                <script>
                    document.querySelector('.contact-form').addEventListener('submit', function() {
                        this.querySelector('[name="_replyto"]').value = this.querySelector('[name="email"]').value;
                    });
                </script>
            </Tile>
        </div>
    </section>

    <style>
        .contact-form { display: grid; gap: 1.25rem; }
        .contact-form label { font-weight: 600; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; color: #555; margin-bottom: 0.15rem; display: block; }
        .contact-form input, .contact-form textarea { width: 100%; padding: 0.6rem 0.75rem; background: #fff; border: none; border-bottom: 2px solid #d1d5db; border-radius: 4px 4px 0 0; font-family: inherit; font-size: 1rem; color: #1e293b; transition: border-color 0.2s ease; outline: none; }
        .contact-form input:focus, .contact-form textarea:focus { border-bottom-color: #6366f1; }
        .contact-form textarea { resize: vertical; }
        .row { display: grid; grid-template-columns: 1fr; gap: 1rem; }
        @media (min-width: 768px) { .row { grid-template-columns: 1fr 1fr; } }
    </style>
</Layout>
