---
import Layout from '@/layouts/Layout.astro';
import { ContentService } from '@/lib/content';
import type { Profile, Project } from '@/types';
import Tile from '@/components/Tile.astro';
import { asset } from '@/utils/paths';
const profile = ContentService.getSync<Profile>('profile');
const projects = ContentService.getSync<Project[]>('projects');
---
<Layout title={`${profile.name} - Projects`} description={`Projects by ${profile.name}`}>
    <div class="band">
        <div class="container">
            <div class="band-header"><h1>Projects</h1></div>
        </div>
    </div>
    <section class="tiles-section container">
        <div class="tiles-grid">
            {projects.map((p, idx) => (
                <Tile
                    title={p.name}
                    subtitle={p.role}
                    meta={p.period}
                    imageSrc={asset(p.image)}
                    imageAlt={p.name}
                    href={p.url}
                    badge={p.tag}
                    aosDelay={idx * 80}
                >
                    <p>{p.summary}</p>
                </Tile>
            ))}
        </div>
    </section>
</Layout>

