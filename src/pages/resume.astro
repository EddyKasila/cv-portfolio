---
import Layout from '@/layouts/Layout.astro';
import { ContentService } from '@/lib/content';
import type { Profile, Experience, Education, Skills } from '@/types';
import Tile from '@/components/Tile.astro';
const profile = ContentService.getSync<Profile>('profile');
const experience = ContentService.getSync<Experience[]>('experience');
const education = ContentService.getSync<Education[]>('education');
const skills = ContentService.getSync<Skills>('skills');
---
<Layout title={`${profile.name} - Resume`} description={`${profile.name} resume`}>
    <div class="band">
        <div class="container">
            <div class="band-header">
                <h1>Resume</h1>
            </div>
        </div>
    </div>
    <section class="tiles-section container">

        <h2>Experience</h2>
        <div class="tiles-grid">
            {experience.map((exp, idx) => (
                <Tile
                    aosDelay={idx * 80}
                    title={exp.role}
                >
                    <div class="d-flex flex-wrap justify-content-between align-items-baseline gap-2 mb-2">
                        <span class="fw-semibold">{exp.company}</span>
                        <span class="text-primary small">{exp.period}</span>
                    </div>
                    <ul>
                        {exp.tasks.map(t => (<li>{t}</li>))}
                    </ul>
                </Tile>
            ))}
        </div>

        <h2 class="mt-4">Education & Skills</h2>
        <div class="tiles-grid">
            <Tile title="Education" aosDelay={0}>
                <ul class="education-list">
                    {education.map(ed => (
                        <li>
                            <div class="degree"><strong>{ed.degree}</strong> – {ed.field}</div>
                            <div class="institution">
                                {ed.institution}
                                <span class="period">{ed.period}</span>
                            </div>
                        </li>
                    ))}
                </ul>
            </Tile>
        </div>
        
        <div class="tiles-grid">
            <Tile title="Skills" aosDelay={80}>
                <ul class="skills-list">
                    {skills.professional.map(s => (<li>{s}</li>))}
                </ul>
                <div class="skills-icons-row">
                    {skills.programming.map(s => (
                        <span class="skills-icon" title={s.name}><i class={s.icon}></i></span>
                    ))}
                </div>
            </Tile>
        </div>
    </section>
</Layout>
