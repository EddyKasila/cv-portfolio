---
import { asset } from '@/utils/paths';
import { AuthService } from '@/lib/auth';
const { username: adminUser, password: adminPass } = AuthService.getStoredCredentials();
const baseUrl = asset('');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="base-url" content={baseUrl} />
  <title>PortfolioOS — Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --primary: #2563eb;
      --primary-light: #eff6ff;
      --primary-ring: rgba(37,99,235,0.12);
      --success: #059669;
      --danger: #dc2626;
      --warning: #d97706;
      --bg: #fafafa;
      --surface: #ffffff;
      --sidebar-bg: #fafafa;
      --border: #e4e4e7;
      --border-light: #f4f4f5;
      --text: #18181b;
      --text-secondary: #71717a;
      --text-muted: #a1a1aa;
      --radius: 12px;
      --radius-sm: 8px;
      --radius-lg: 16px;
      --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
      --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
      --shadow-md: 0 4px 12px rgba(0,0,0,0.05), 0 1px 3px rgba(0,0,0,0.04);
      --shadow-lg: 0 10px 30px rgba(0,0,0,0.08);
      --topnav-height: 56px;
      --sidebar-width: 240px;
    }
    html { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
    body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; margin: 0; }

    /* ── Top Nav ── */
    .topnav { position: fixed; top: 0; left: 0; right: 0; height: var(--topnav-height); background: rgba(255,255,255,0.8); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); display: flex; align-items: center; padding: 0 20px; z-index: 50; gap: 12px; }
    .topnav-logo { font-size: 1.1rem; font-weight: 700; color: var(--text); letter-spacing: -0.03em; display: flex; align-items: center; gap: 8px; white-space: nowrap; }
    .topnav-logo span { color: var(--primary); }
    .topnav-spacer { flex: 1; }
    .topnav-search { position: relative; width: 240px; }
    .topnav-search input { width: 100%; padding: 7px 12px 7px 32px; border: 1px solid var(--border); border-radius: 8px; font-size: 0.8rem; font-family: inherit; background: var(--surface); color: var(--text); outline: none; transition: border-color 0.15s; }
    .topnav-search input:focus { border-color: var(--primary); }
    .topnav-search i { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); font-size: 0.75rem; color: var(--text-muted); pointer-events: none; }
    .topnav-btn { width: 34px; height: 34px; border: 1px solid var(--border); border-radius: 8px; background: var(--surface); color: var(--text-secondary); cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; transition: all 0.15s; }
    .topnav-btn:hover { background: #f4f4f5; color: var(--text); }
    .topnav-avatar { width: 32px; height: 32px; border-radius: 8px; background: var(--primary); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700; cursor: pointer; transition: opacity 0.15s; }
    .topnav-avatar:hover { opacity: 0.85; }
    .topnav-actions { display: flex; align-items: center; gap: 8px; }

    /* ── Layout ── */
    .app { display: flex; padding-top: var(--topnav-height); min-height: 100vh; }

    /* ── Sidebar ── */
    .sidebar { width: var(--sidebar-width); background: var(--sidebar-bg); border-right: 1px solid var(--border); position: fixed; top: var(--topnav-height); left: 0; bottom: 0; z-index: 40; overflow-y: auto; padding: 12px 8px; transition: transform 0.25s ease; display: flex; flex-direction: column; }
    .sidebar-group { margin-bottom: 4px; }
    .sidebar-label { font-size: 0.65rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; padding: 12px 12px 6px; }
    .sidebar-item { display: flex; align-items: center; gap: 10px; padding: 8px 12px; border-radius: 8px; font-size: 0.85rem; font-weight: 500; color: var(--text-secondary); cursor: pointer; transition: all 0.12s; border: none; background: none; width: 100%; text-align: left; font-family: inherit; }
    .sidebar-item:hover { background: var(--border-light); color: var(--text); }
    .sidebar-item.active { background: var(--primary-light); color: var(--primary); font-weight: 600; }
    .sidebar-item i { width: 18px; text-align: center; font-size: 0.85rem; flex-shrink: 0; }
    .sidebar-item .badge { margin-left: auto; font-size: 0.6rem; background: var(--border-light); padding: 2px 8px; border-radius: 4px; color: var(--text-muted); font-weight: 600; }
    .sidebar-item.disabled { opacity: 0.4; cursor: not-allowed; }
    .sidebar-spacer { flex: 1; }
    .sidebar-footer { padding: 8px 4px 4px; border-top: 1px solid var(--border-light); margin-top: 8px; }

    /* ── Main ── */
    .main { margin-left: var(--sidebar-width); flex: 1; padding: 32px; max-width: 1100px; min-height: calc(100vh - var(--topnav-height)); }
    .page-header { margin-bottom: 28px; }
    .page-header h2 { font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; color: var(--text); }
    .page-header p { color: var(--text-secondary); font-size: 0.9rem; margin-top: 4px; }

    /* ── Stat Cards ── */
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: 16px; margin-bottom: 32px; }
    .stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; box-shadow: var(--shadow-sm); transition: box-shadow 0.2s, transform 0.2s; cursor: default; }
    .stat-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
    .stat-icon { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1rem; margin-bottom: 12px; }
    .stat-value { font-size: 1.35rem; font-weight: 700; letter-spacing: -0.02em; }
    .stat-label { font-size: 0.8rem; color: var(--text-secondary); margin-top: 2px; }
    .stat-desc { font-size: 0.75rem; color: var(--text-muted); margin-top: 6px; }

    /* ── Content Cards ── */
    .content-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow-sm); overflow: hidden; }
    .content-card-header { padding: 20px 24px; border-bottom: 1px solid var(--border-light); display: flex; align-items: center; justify-content: space-between; }
    .content-card-header h3 { font-size: 1rem; font-weight: 600; }
    .content-card-body { padding: 20px 24px; }

    /* ── Items (card-style table) ── */
    .item-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 16px 20px; display: flex; align-items: center; justify-content: space-between; gap: 16px; transition: box-shadow 0.15s; }
    .item-card:hover { box-shadow: var(--shadow); }
    .item-card-left { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
    .item-card-title { font-size: 0.9rem; font-weight: 600; color: var(--text); }
    .item-card-sub { font-size: 0.8rem; color: var(--text-secondary); }
    .item-card-meta { font-size: 0.75rem; color: var(--text-muted); }
    .item-card-actions { display: flex; gap: 6px; flex-shrink: 0; }

    /* ── Modal ── */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); z-index: 200; display: none; align-items: center; justify-content: center; padding: 20px; animation: fadeIn 0.15s ease; }
    .modal-overlay.open { display: flex; }
    .modal { background: var(--surface); border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); width: 100%; max-width: 560px; max-height: 85vh; overflow-y: auto; animation: scaleIn 0.2s ease; }
    .modal-header { padding: 24px 28px 0; display: flex; align-items: center; justify-content: space-between; }
    .modal-header h3 { font-size: 1.15rem; font-weight: 700; }
    .modal-close { width: 32px; height: 32px; border: none; border-radius: 8px; background: transparent; color: var(--text-muted); cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; transition: background 0.12s; }
    .modal-close:hover { background: var(--border-light); color: var(--text); }
    .modal-body { padding: 20px 28px; }
    .modal-footer { padding: 16px 28px 24px; display: flex; gap: 10px; justify-content: flex-end; border-top: 1px solid var(--border-light); }

    /* ── Buttons ── */
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 18px; border: none; border-radius: 8px; font-size: 0.85rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: all 0.12s; }
    .btn:active { transform: scale(0.98); }
    .btn-primary { background: var(--primary); color: #fff; }
    .btn-primary:hover { background: #1d4ed8; }
    .btn-secondary { background: var(--border-light); color: var(--text); }
    .btn-secondary:hover { background: #e4e4e7; }
    .btn-danger { background: var(--danger); color: #fff; }
    .btn-danger:hover { background: #b91c1c; }
    .btn-ghost { background: transparent; color: var(--text-secondary); }
    .btn-ghost:hover { background: var(--border-light); color: var(--text); }
    .btn-sm { padding: 5px 12px; font-size: 0.8rem; }
    .btn-icon { width: 34px; height: 34px; padding: 0; display: flex; align-items: center; justify-content: center; border-radius: 8px; }

    /* ── Forms ── */
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 0.8rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 5px; }
    .form-input { width: 100%; padding: 9px 12px; border: 1.5px solid var(--border); border-radius: 8px; font-size: 0.9rem; font-family: inherit; background: var(--surface); color: var(--text); outline: none; transition: border-color 0.15s, box-shadow 0.15s; }
    .form-input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px var(--primary-ring); }
    textarea.form-input { resize: vertical; min-height: 100px; line-height: 1.5; }

    /* ── Badge ── */
    .badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 10px; border-radius: 6px; font-size: 0.7rem; font-weight: 600; }
    .badge-success { background: #ecfdf5; color: var(--success); }
    .badge-warning { background: #fffbeb; color: var(--warning); }

    /* ── Toast ── */
    .toast { position: fixed; bottom: 24px; right: 24px; padding: 12px 20px; border-radius: 10px; font-size: 0.85rem; font-weight: 500; color: #fff; box-shadow: var(--shadow-lg); transform: translateY(16px); opacity: 0; transition: all 0.3s ease; z-index: 300; display: flex; align-items: center; gap: 8px; }
    .toast.show { transform: translateY(0); opacity: 1; }
    .toast-success { background: var(--success); }
    .toast-error { background: var(--danger); }

    /* ── Loading ── */
    .loading-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 60px 20px; color: var(--text-muted); }
    .loading-state i { font-size: 1.5rem; margin-bottom: 12px; }
    .loading-state div { font-size: 0.85rem; }

    /* ── Empty State ── */
    .empty-state { text-align: center; padding: 48px 20px; color: var(--text-muted); }
    .empty-state i { font-size: 2rem; margin-bottom: 12px; }
    .empty-state h3 { font-size: 1rem; color: var(--text); margin-bottom: 4px; }
    .empty-state p { font-size: 0.85rem; }

    /* ── Animations ── */
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @keyframes scaleIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
    @keyframes slideUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    .animate-in { animation: slideUp 0.25s ease both; }

    /* ── Mobile ── */
    .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.3); z-index: 39; }
    .mobile-nav-toggle { display: none; }

    @media (max-width: 768px) {
      .sidebar { transform: translateX(-100%); }
      .sidebar.open { transform: translateX(0); }
      .sidebar-overlay.open { display: block; }
      .mobile-nav-toggle { display: flex; }
      .main { margin-left: 0; padding: 20px; padding-top: 8px; }
      .stats-grid { grid-template-columns: 1fr 1fr; }
      .topnav-search { width: 140px; }
      .modal { max-width: 100%; margin: 10px; max-height: 90vh; }
      .modal-body, .modal-header, .modal-footer { padding-left: 20px; padding-right: 20px; }
    }
    @media (max-width: 480px) {
      .stats-grid { grid-template-columns: 1fr; }
      .topnav-search { display: none; }
    }
  </style>
</head>
<body>
  <!-- Top Nav -->
  <header class="topnav">
    <button class="topnav-btn mobile-nav-toggle" id="mobileNavToggle" aria-label="Toggle menu">
      <i class="fa-solid fa-bars"></i>
    </button>
    <div class="topnav-logo">Portfolio<span>OS</span></div>
    <div class="topnav-spacer"></div>
    <div class="topnav-search">
      <i class="fa-solid fa-search"></i>
      <input type="text" placeholder="Search..." id="globalSearch" />
    </div>
    <div class="topnav-actions">
      <button class="topnav-btn" id="themeToggle" title="Toggle theme" style="display:none;">
        <i class="fa-regular fa-moon"></i>
      </button>
      <button class="topnav-btn" title="Notifications (coming soon)" disabled>
        <i class="fa-regular fa-bell"></i>
      </button>
      <div class="topnav-avatar" id="userAvatar" title="Admin">EN</div>
    </div>
  </header>

  <!-- Overlay -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <!-- App -->
  <div class="app">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <nav id="sidebarNav"></nav>
      <div class="sidebar-spacer"></div>
      <div class="sidebar-footer">
        <button class="sidebar-item" id="logoutBtn">
          <i class="fa-solid fa-right-from-bracket"></i>
          <span>Logout</span>
        </button>
      </div>
    </aside>

    <!-- Main -->
    <main class="main" id="adminContent">
      <div class="loading-state">
        <i class="fa-solid fa-circle-notch fa-spin"></i>
        <div>Loading...</div>
      </div>
    </main>
  </div>

  <!-- Modal container -->
  <div class="modal-overlay" id="modalOverlay">
    <div class="modal" id="modalContent"></div>
  </div>

  <!-- Toast container -->
  <div class="toast" id="toast"></div>

  <script>
    import { adminApp, renderDashboard, renderProfile, renderExperience, renderProjects, renderEducation, renderSkills, renderCertifications, renderSettings } from '@/lib/admin';

    adminApp.register({ id: 'dashboard', label: 'Dashboard', icon: 'fa-gauge-high', enabled: true, render: renderDashboard });
    adminApp.register({ id: 'profile', label: 'Profile', icon: 'fa-user', enabled: true, render: renderProfile });
    adminApp.register({ id: 'experience', label: 'Experience', icon: 'fa-briefcase', enabled: true, render: renderExperience });
    adminApp.register({ id: 'projects', label: 'Projects', icon: 'fa-diagram-project', enabled: true, render: renderProjects });
    adminApp.register({ id: 'education', label: 'Education', icon: 'fa-graduation-cap', enabled: true, render: renderEducation });
    adminApp.register({ id: 'skills', label: 'Skills', icon: 'fa-code', enabled: true, render: renderSkills });
    adminApp.register({ id: 'certifications', label: 'Certifications', icon: 'fa-certificate', enabled: true, render: renderCertifications });
    adminApp.register({ id: 'settings', label: 'Settings', icon: 'fa-gear', enabled: true, render: renderSettings });
    adminApp.register({ id: 'articles', label: 'Articles', icon: 'fa-newspaper', enabled: false });
    adminApp.register({ id: 'contact', label: 'Contact', icon: 'fa-envelope', enabled: false });
    adminApp.register({ id: 'seo', label: 'SEO', icon: 'fa-magnifying-glass', enabled: false });

    adminApp.boot();

    // Mobile nav
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebarOverlay');
    document.getElementById('mobileNavToggle').addEventListener('click', () => {
      sidebar.classList.toggle('open');
      overlay.classList.toggle('open');
    });
    overlay.addEventListener('click', () => {
      sidebar.classList.remove('open');
      overlay.classList.remove('open');
    });
  </script>
</body>
</html>
