---
import { asset } from '@/utils/paths';
import { AuthService } from '@/lib/auth';
const { username: adminUser, password: adminPass } = AuthService.getStoredCredentials();
const adminUrl = asset('/admin/');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>PortfolioOS — Login</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%); display: flex; align-items: center; justify-content: center; min-height: 100vh; font-family: system-ui, -apple-system, sans-serif; padding: 1rem; }
    .login-card { background: rgba(255,255,255,0.85); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-radius: 20px; box-shadow: 0 8px 32px rgba(0,0,0,0.08); padding: 2.5rem; width: 100%; max-width: 400px; border: 1px solid rgba(255,255,255,0.5); }
    .login-card h1 { font-size: 1.5rem; font-weight: 700; margin-bottom: 0.25rem; color: #1e293b; }
    .login-card p { color: #64748b; margin-bottom: 1.5rem; font-size: 0.9rem; }
    .login-card .form-control { border-radius: 10px; padding: 0.7rem 1rem; border: 1.5px solid #e2e8f0; background: #fff; transition: border-color 0.2s, box-shadow 0.2s; }
    .login-card .form-control:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,0.1); outline: none; }
    .login-card .btn { border-radius: 10px; padding: 0.7rem; font-weight: 600; background: linear-gradient(135deg, #6366f1, #8b5cf6); border: none; transition: transform 0.15s, box-shadow 0.15s; }
    .login-card .btn:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(99,102,241,0.3); }
    .login-error { color: #dc2626; font-size: 0.85rem; margin-top: 0.5rem; display: none; }
    .logo { font-size: 2rem; font-weight: 800; background: linear-gradient(135deg, #6366f1, #8b5cf6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 0.5rem; }
    .form-label { font-weight: 600; font-size: 0.85rem; color: #475569; margin-bottom: 0.35rem; }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="logo">PortfolioOS</div>
    <h1>Welcome back</h1>
    <p>Sign in to manage your portfolio</p>
    <form id="loginForm" data-redirect={adminUrl} data-username={adminUser} data-password={adminPass}>
      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input type="text" class="form-control" id="username" required autocomplete="username" />
      </div>
      <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input type="password" class="form-control" id="password" required autocomplete="current-password" />
      </div>
      <button type="submit" class="btn btn-primary w-100">Sign in</button>
      <div class="login-error" id="loginError">Invalid username or password</div>
    </form>
  </div>
  <script is:inline>
    (function() {
      var form = document.getElementById('loginForm');
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var u = document.getElementById('username').value;
        var p = document.getElementById('password').value;
        if (u === this.getAttribute('data-username') && p === this.getAttribute('data-password')) {
          var session = { authenticated: true, loginTime: Date.now(), expiry: Date.now() + 86400000 };
          localStorage.setItem('portfolioos_auth', JSON.stringify(session));
          window.location.href = this.getAttribute('data-redirect');
        } else {
          document.getElementById('loginError').style.display = 'block';
        }
      });
    })();
  </script>
</body>
</html>
