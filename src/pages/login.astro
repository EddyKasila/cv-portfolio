---
import { asset } from '@/utils/paths';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>PortfolioOS — Login</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <style>
    body { background: #f1f5f9; display: flex; align-items: center; justify-content: center; min-height: 100vh; font-family: system-ui, -apple-system, sans-serif; }
    .login-card { background: #fff; border-radius: 16px; box-shadow: 0 4px 24px rgba(0,0,0,0.08); padding: 2.5rem; width: 100%; max-width: 400px; }
    .login-card h1 { font-size: 1.5rem; font-weight: 700; margin-bottom: 0.25rem; }
    .login-card p { color: #64748b; margin-bottom: 1.5rem; font-size: 0.9rem; }
    .login-card .form-control { border-radius: 10px; padding: 0.7rem 1rem; }
    .login-card .btn { border-radius: 10px; padding: 0.7rem; font-weight: 600; }
    .login-error { color: #dc2626; font-size: 0.85rem; margin-top: 0.5rem; display: none; }
    .logo { font-size: 2rem; font-weight: 800; background: linear-gradient(135deg, #6366f1, #8b5cf6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 0.5rem; }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="logo">PortfolioOS</div>
    <h1>Welcome back</h1>
    <p>Sign in to manage your portfolio</p>
    <form id="loginForm">
      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input type="text" class="form-control" id="username" required autocomplete="username" />
      </div>
      <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input type="password" class="form-control" id="password" required autocomplete="current-password" />
      </div>
      <button type="submit" class="btn btn-primary w-100">Sign in</button>
      <div class="login-error" id="loginError">Invalid username or password</div>
    </form>
  </div>
  <script>
    const ADMIN_USERNAME = 'admin';
    const ADMIN_PASSWORD = 'portfolioos2024';
    document.getElementById('loginForm').addEventListener('submit', function(e) {
      e.preventDefault();
      const username = document.getElementById('username').value;
      const password = document.getElementById('password').value;
      if (username === ADMIN_USERNAME && password === ADMIN_PASSWORD) {
        const session = { authenticated: true, loginTime: Date.now(), expiry: Date.now() + 86400000 };
        localStorage.setItem('portfolioos_auth', JSON.stringify(session));
        window.location.href = '{asset("/admin")}';
      } else {
        document.getElementById('loginError').style.display = 'block';
      }
    });
  </script>
</body>
</html>
