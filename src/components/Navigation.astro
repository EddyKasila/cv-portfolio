---
import { ContentService } from '@/lib/content';
import type { Profile } from '@/types';
import { asset } from '@/utils/paths';
const profile = ContentService.getSync<Profile>('profile');

const navLinks = [
  { name: 'Home', url: '/' },
  { name: 'Resume', url: '/resume' },
  { name: 'Projects', url: '/projects' },
  { name: 'Contact', url: '/contact' },
];
---
<nav class="navbar navbar-expand-lg navbar-dark fixed-top top-nav">
  <div class="container">
    <a class="navbar-brand fw-bold" href={asset('/')}>{profile.name}</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto">
        {navLinks.map(link => (
          <li class="nav-item">
            <a class="nav-link" href={asset(link.url)}>{link.name}</a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</nav>

<style>
  .top-nav {
    background: rgba(99, 102, 241, 0.65);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    box-shadow: 0 1px 12px rgba(0,0,0,0.1);
    padding: 0.5rem 0;
  }
  .top-nav .navbar-brand {
    font-size: 1.25rem;
    letter-spacing: 0.02em;
  }
  .top-nav .nav-link {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.85rem;
    padding: 0.5rem 1rem !important;
    border-radius: 6px;
    transition: background 0.2s ease;
  }
  .top-nav .nav-link:hover {
    background: rgba(255,255,255,0.15);
  }
</style>